# Database Configuration
# For local PostgreSQL:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=csidc_industrial
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# For Supabase (managed PostgreSQL):
# POSTGRES_HOST=db.xxxxxxxxxxxxx.supabase.co
# POSTGRES_PORT=5432
# POSTGRES_DB=postgres
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_supabase_password

# Google Earth Engine
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=E:\github_projects\xcelerateGroundwork\backend\gee-key.json

# API Configuration
SECRET_KEY=change-this-to-a-random-secret-key
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Scheduler (optional - for automated analysis runs)
ANALYSIS_CRON=0 3 1 * *
